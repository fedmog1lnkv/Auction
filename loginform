<!doctype html>
<html lang="ru">
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Авторизация</title>
    <link rel="stylesheet" href="">  <!--Связываем с классом href="" CSS-->
</head>
<body>

    <main class="Form">

            <div class="Form1">
                <h1>Добро пожаловать в личный кабинет</h1>
                <p>Войти или зарегестрировать новый аккаунт.</p>
            </div>

                <div class="Form2">
                    <button class="tabBtn active" type="button" data-tab="loginForm">Войти</button>
                    <button class="tabBtn" type="button" data-tab="regForm">Регистрация</button>
                </div>

                <form class="dataentryform">
                    <!--Вводим электронную почту-->
                    <div class="tabs1">
                        <label>Электронная почта</label>
                        <input type="email" name="email" placeholder="Электронная почта" required>
                    </div>
                    <!--Вводим пароль-->
                    <div class="tab2">
                        <label>Пароль</label>
                        <input type="password" name="password" placeholder="Введите пароль" required>
                    </div>

                    <button class="btn" type="submit">Войти</button>
                </form>

                <form class="form" id="regForm">
                    <!--Вводим имя-->
                    <div class="row">
                            <label>Имя</label>
                            <input type="text" placeholder="Имя" required>
                        </div>
                          <!--Вводим фамилию-->
                        <div class="inputBlock">
                            <label>Фамилия</label>
                            <input type="text" placeholder="Фамилия" required>
                        </div>
                    </div>
                    <!--Ввод электронной почты-->
                    <div class="input1">
                        <input type="email" name="email" placeholder="Электронная почта" required>
                    </div>
                    <!--Ввод пароля-->
                    <div class="input2">
                        <input type="password" name="password" placeholder="Минимум 8 символов" required>
                    </div>
                    <!--Кнопка создания ака-->
                    <button class="btn" type="submit">Создать аккаунт</button>
                </form>
            </div>
    </main>

    <script src=""></script>  <!-- Связываем с JS-->
</body>
</html>
